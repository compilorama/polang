{
  "name": "@compilorama/polang",
  "version": "0.1.0",
  "description": "Tiny i18n library for tiny React webapps",
  "keywords": [
    "lightweight",
    "i18n",
    "translation",
    "multi-language"
  ],
  "license": "MIT",
  "author": "Rafael Camargo <hello@rafaelcamargo.com>",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/es6/index.js",
  "exports": {
    "require": "./dist/cjs/index.js",
    "import": "./dist/es6/index.js"
  },
  "scripts": {
    "build": "rm -rf dist && babel src --out-dir dist/cjs --env-name cjs --ignore '**/*.test.js','**/services/testing.js' && babel src --out-dir dist/es6 --env-name es6 --ignore '**/*.test.js','**/services/testing.js' && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
    "format": "eslint src",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
